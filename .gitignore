# 忽略小说文件夹中的内容，但保留文件夹本身
novel/*
!novel/.gitkeep

# 忽略角色图片文件夹中的内容，但保留文件夹本身
role/*
!role/.gitkeep

# 忽略API密钥文件
kimi api_key.txt

# 忽略生成的结果文件
storyboard_result.json

# 忽略Python编译文件
__pycache__/
*.py[cod]
*$py.class
*.so

# 忽略环境变量文件
.env
.env.local
.env.*.local

# 忽略数据库配置文件
db_config.json

# 忽略日志文件
*.log
logs/

# 忽略临时文件
*.tmp
*.temp
tmp/
temp/

# 忽略编辑器文件
.vscode/
.idea/
*.swp
*.swo
*~

# 忽略Trae IDE配置文件
.trae/

# 忽略项目思路文件
项目思路文件.txt
